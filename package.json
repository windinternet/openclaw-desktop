{
  "name": "openclaw-desktop",
  "version": "0.1.0",
  "description": "OpenClaw Desktop Client",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "vite",
    "preview": "vite preview",
    "electron:build": "vite build && electron-builder",
    "lint": "eslint src/ electron/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ electron/ --ext .ts,.tsx --fix",
    "stylelint": "stylelint \"src/**/*.{css,less,scss}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,less,scss}\" --fix",
    "format": "prettier \"src/**/*.{ts,tsx,js,jsx,json,css,less,md}\" --check",
    "format:fix": "prettier \"src/**/*.{ts,tsx,js,jsx,json,css,less,md}\" --write",
    "check": "npm run lint && npm run format && npm run stylelint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@douyinfe/semi-icons": "^2.74.0",
    "@douyinfe/semi-illustrations": "^2.74.0",
    "@douyinfe/semi-ui": "^2.74.0",
    "i18next": "^26.2.0",
    "marked": "^18.0.4",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^1.0.0-beta.11",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.0"
  },
  "build": {
    "appId": "ai.openclaw.desktop",
    "productName": "OpenClaw Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
