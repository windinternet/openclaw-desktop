{
  "name": "openclaw-desktop",
  "version": "0.1.0",
  "description": "OpenClaw Desktop Client",
  "author": "OpenClaw",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "vite",
    "preview": "vite preview",
    "electron:build": "npm run build && electron-builder --publish never",
    "electron:build:linux": "npm run build && electron-builder --linux AppImage deb rpm tar.gz --publish never",
    "electron:build:mac": "npm run build && electron-builder --mac dmg zip --publish never",
    "electron:build:win": "npm run build && electron-builder --win nsis portable --publish never",
    "lint": "eslint src/ electron/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ electron/ --ext .ts,.tsx --fix",
    "stylelint": "stylelint \"src/**/*.{css,less,scss}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,less,scss}\" --fix",
    "format": "prettier \"src/**/*.{ts,tsx,js,jsx,json,css,less,md}\" --check",
    "format:fix": "prettier \"src/**/*.{ts,tsx,js,jsx,json,css,less,md}\" --write",
    "check": "npm run lint && npm run format && npm run stylelint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@douyinfe/semi-icons": "^2.74.0",
    "@douyinfe/semi-illustrations": "^2.74.0",
    "@douyinfe/semi-ui": "^2.74.0",
    "i18next": "^26.2.0",
    "marked": "^18.0.4",
    "playwright": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1",
    "react-virtualized": "^9.22.6",
    "three": "^0.184.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-virtualized": "^9.22.3",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^1.0.0-beta.11",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.0"
  },
  "build": {
    "appId": "ai.openclaw.desktop",
    "productName": "OpenClaw Desktop",
    "artifactName": "OpenClaw-Desktop-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "OpenClaw-Desktop-${version}-win-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "OpenClaw-Desktop-${version}-win-${arch}-portable.${ext}"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "artifactName": "OpenClaw-Desktop-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "maintainer": "OpenClaw",
      "category": "Development",
      "executableName": "openclaw-desktop",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  }
}
